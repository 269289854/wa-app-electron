{
  "name": "wa-app-electron",
  "version": "1.0.1",
  "private": true,
  "description": "Cross-platform desktop client for wa-app.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && npm run electron:dev\"",
    "build:electron": "tsc -p electron/tsconfig.json",
    "assets:brand": "powershell -ExecutionPolicy Bypass -File scripts/generate-brand-assets.ps1",
    "electron:dev": "npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "build": "npm run typecheck && vite build && npm run build:electron",
    "smoke:electron": "powershell -ExecutionPolicy Bypass -File scripts/smoke-electron.ps1",
    "smoke:mock-ui": "powershell -ExecutionPolicy Bypass -File scripts/smoke-mock-ui.ps1",
    "smoke:remote-api": "powershell -ExecutionPolicy Bypass -File scripts/smoke-remote-api.ps1",
    "dist": "npm run build && electron-builder",
    "dist:x64": "electron-builder --win nsis zip --x64",
    "dist:ia32": "electron-builder --win nsis zip --ia32",
    "dist:win": "npm run dist:x64 && npm run dist:ia32",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.11",
    "clsx": "^2.1.1",
    "libphonenumber-js": "^1.13.6",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^10.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "uk.yizhimeng.waapp",
    "productName": "WA App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WA App",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  }
}
